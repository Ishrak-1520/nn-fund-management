<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Approval History: Tree View                                   -->
    <!-- ============================================================ -->
    <record id="view_approval_history_tree" model="ir.ui.view">
        <field name="name">nn.approval.history.list</field>
        <field name="model">nn.approval.history</field>
        <field name="arch" type="xml">
            <list string="Approval History" create="false" edit="false" delete="false"
                  decoration-success="action in ('gm_approve', 'md_approve')"
                  decoration-danger="action in ('gm_reject', 'md_reject')"
                  decoration-warning="action == 'cancel'"
                  decoration-info="action == 'submit'"
                  decoration-muted="action == 'reset_draft'">
                <field name="date" widget="datetime"/>
                <field name="reference"/>
                <field name="res_model" string="Document Type"/>
                <field name="action"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="previous_state"/>
                <field name="new_state"/>
                <field name="amount" widget="monetary"/>
                <field name="fund_account_id" optional="show"/>
                <field name="project_id" optional="show"/>
                <field name="expense_head_id" optional="show"/>
                <field name="comment" optional="hide"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Approval History: Form View (read-only)                       -->
    <!-- ============================================================ -->
    <record id="view_approval_history_form" model="ir.ui.view">
        <field name="name">nn.approval.history.form</field>
        <field name="model">nn.approval.history</field>
        <field name="arch" type="xml">
            <form string="Approval History" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group string="Action Details">
                            <field name="action"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="date" widget="datetime"/>
                            <field name="previous_state"/>
                            <field name="new_state"/>
                        </group>
                        <group string="Related Records">
                            <field name="reference"/>
                            <field name="res_model"/>
                            <field name="amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="fund_account_id"/>
                            <field name="project_id"/>
                            <field name="expense_head_id"/>
                        </group>
                    </group>
                    <group string="Comment" attrs="{'invisible': [('comment', '=', False)]}">
                        <field name="comment" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Approval History: Search View                                 -->
    <!-- ============================================================ -->
    <record id="view_approval_history_search" model="ir.ui.view">
        <field name="name">nn.approval.history.search</field>
        <field name="model">nn.approval.history</field>
        <field name="arch" type="xml">
            <search string="Search Approval History">
                <field name="reference"/>
                <field name="user_id"/>
                <field name="fund_account_id"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <separator/>
                <filter name="filter_submitted" string="Submitted"
                        domain="[('action', '=', 'submit')]"/>
                <filter name="filter_approved" string="Approved"
                        domain="[('action', 'in', ['gm_approve', 'md_approve'])]"/>
                <filter name="filter_rejected" string="Rejected"
                        domain="[('action', 'in', ['gm_reject', 'md_reject'])]"/>
                <filter name="filter_cancelled" string="Cancelled"
                        domain="[('action', '=', 'cancel')]"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('date', '&gt;=', (context_today()).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_week" string="This Week"
                        domain="[('date', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_month" string="This Month"
                        domain="[('date', '&gt;=', (context_today()).strftime('%Y-%m-01'))]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_by_action" string="Action" context="{'group_by': 'action'}"/>
                    <filter name="group_by_user" string="User" context="{'group_by': 'user_id'}"/>
                    <filter name="group_by_model" string="Document Type" context="{'group_by': 'res_model'}"/>
                    <filter name="group_by_project" string="Project" context="{'group_by': 'project_id'}"/>
                    <filter name="group_by_date" string="Date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Approval History: Action                                      -->
    <!-- ============================================================ -->
    <record id="action_approval_history" model="ir.actions.act_window">
        <field name="name">Approval History</field>
        <field name="res_model">nn.approval.history</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_approval_history_search"/>
        <field name="context">{'search_default_filter_this_month': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No approval history yet.
            </p>
            <p>
                Approval history is automatically created when fund requests
                are submitted, approved, rejected, or cancelled.
            </p>
        </field>
    </record>

</odoo>
