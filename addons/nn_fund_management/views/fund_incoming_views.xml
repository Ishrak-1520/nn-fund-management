<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Fund Incoming: Tree View                                      -->
    <!-- ============================================================ -->
    <record id="view_fund_incoming_tree" model="ir.ui.view">
        <field name="name">nn.fund.incoming.tree</field>
        <field name="model">nn.fund.incoming</field>
        <field name="arch" type="xml">
            <tree string="Incoming Funds"
                  decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="date"/>
                <field name="fund_account_id"/>
                <field name="amount" widget="monetary" sum="Total"/>
                <field name="transaction_reference"/>
                <field name="sender"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-info="state == 'draft'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="currency_id" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Fund Incoming: Form View                                      -->
    <!-- ============================================================ -->
    <record id="view_fund_incoming_form" model="ir.ui.view">
        <field name="name">nn.fund.incoming.form</field>
        <field name="model">nn.fund.incoming</field>
        <field name="arch" type="xml">
            <form string="Incoming Fund">
                <header>
                    <button name="action_confirm" type="object"
                            string="Confirm" class="btn-primary"
                            invisible="state != 'draft'"
                            groups="nn_fund_management.group_finance_user"/>
                    <button name="action_cancel" type="object"
                            string="Cancel" class="btn-secondary"
                            invisible="state not in ('draft', 'confirmed')"
                            confirm="Are you sure you want to cancel this incoming fund?"/>
                    <button name="action_reset_to_draft" type="object"
                            string="Reset to Draft" class="btn-secondary"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Fund Details">
                            <field name="fund_account_id"/>
                            <field name="date"/>
                            <field name="amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Transaction Info">
                            <field name="transaction_reference"
                                   placeholder="e.g. Bank TXN-2026-001"/>
                            <field name="sender" placeholder="e.g. Client XYZ"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Confirmation" invisible="state != 'confirmed'">
                        <field name="confirmed_by"/>
                        <field name="confirmed_date"/>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"
                                   placeholder="Additional details about this incoming fund..."/>
                        </page>
                        <page string="Attachments" name="attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Fund Incoming: Search View                                    -->
    <!-- ============================================================ -->
    <record id="view_fund_incoming_search" model="ir.ui.view">
        <field name="name">nn.fund.incoming.search</field>
        <field name="model">nn.fund.incoming</field>
        <field name="arch" type="xml">
            <search string="Search Incoming Funds">
                <field name="name"/>
                <field name="fund_account_id"/>
                <field name="transaction_reference"/>
                <field name="sender"/>
                <separator/>
                <filter name="filter_draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_cancelled" string="Cancelled"
                        domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter name="filter_this_month" string="This Month"
                        domain="[('date', '&gt;=', (context_today()).strftime('%Y-%m-01'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_account" string="Fund Account"
                            context="{'group_by': 'fund_account_id'}"/>
                    <filter name="group_by_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_by_date" string="Date"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Fund Incoming: Action                                         -->
    <!-- ============================================================ -->
    <record id="action_fund_incoming" model="ir.actions.act_window">
        <field name="name">Incoming Funds</field>
        <field name="res_model">nn.fund.incoming</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_fund_incoming_search"/>
        <field name="context">{'search_default_filter_confirmed': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record a new incoming fund
            </p>
            <p>
                Record money received from banks, clients, or other sources.
                After confirmation, the amount is added to the fund account's
                unassigned balance.
            </p>
        </field>
    </record>

</odoo>
