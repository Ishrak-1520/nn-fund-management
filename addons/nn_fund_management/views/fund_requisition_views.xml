<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Fund Requisition: Tree View                                   -->
    <!-- ============================================================ -->
    <record id="view_fund_requisition_tree" model="ir.ui.view">
        <field name="name">nn.fund.requisition.tree</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <tree string="Fund Requisitions"
                  decoration-success="state == 'approved'"
                  decoration-warning="state in ('submitted', 'gm_approved')"
                  decoration-danger="state == 'rejected'"
                  decoration-muted="state in ('cancelled', 'closed')">
                <field name="name"/>
                <field name="request_date"/>
                <field name="allocation_type"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="amount" widget="monetary" sum="Total"/>
                <field name="total_billed" widget="monetary" sum="Total"/>
                <field name="remaining_billable" widget="monetary"
                       decoration-danger="remaining_billable &lt;= 0"
                       decoration-success="remaining_billable &gt; 0"/>
                <field name="requested_by" widget="many2one_avatar_user"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state in ('submitted', 'gm_approved')"
                       decoration-danger="state == 'rejected'"
                       decoration-info="state == 'draft'"
                       decoration-muted="state in ('cancelled', 'closed')"/>
                <field name="currency_id" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Fund Requisition: Form View                                   -->
    <!-- ============================================================ -->
    <record id="view_fund_requisition_form" model="ir.ui.view">
        <field name="name">nn.fund.requisition.form</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <form string="Fund Requisition">
                <header>
                    <button name="action_submit" type="object"
                            string="Submit" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_gm_approve" type="object"
                            string="GM Approve" class="btn-primary"
                            invisible="state != 'submitted'"
                            groups="nn_fund_management.group_gm_approver"/>
                    <button name="action_gm_reject" type="object"
                            string="GM Reject" class="btn-danger"
                            invisible="state != 'submitted'"
                            groups="nn_fund_management.group_gm_approver"/>
                    <button name="action_md_approve" type="object"
                            string="MD Approve" class="btn-primary"
                            invisible="state != 'gm_approved'"
                            groups="nn_fund_management.group_md_approver"/>
                    <button name="action_md_reject" type="object"
                            string="MD Reject" class="btn-danger"
                            invisible="state != 'gm_approved'"
                            groups="nn_fund_management.group_md_approver"/>
                    <button name="action_close" type="object"
                            string="Close Requisition" class="btn-secondary"
                            invisible="state != 'approved'"
                            confirm="Close this requisition? Any remaining billable amount will be released."/>
                    <button name="action_cancel" type="object"
                            string="Cancel" class="btn-secondary"
                            invisible="state in ('draft', 'rejected', 'cancelled', 'closed')"
                            confirm="Are you sure you want to cancel this requisition?"/>
                    <button name="action_reset_to_draft" type="object"
                            string="Reset to Draft" class="btn-secondary"
                            invisible="state not in ('rejected', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,gm_approved,approved,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bills" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                invisible="state not in ('approved', 'closed')">
                            <field name="bill_count" widget="statinfo" string="Bills"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Requisition Details">
                            <field name="allocation_type" widget="radio"/>
                            <field name="project_id"
                                   invisible="allocation_type != 'project'"
                                   required="allocation_type == 'project'"/>
                            <field name="expense_head_id"
                                   invisible="allocation_type != 'expense_head'"
                                   required="allocation_type == 'expense_head'"/>
                            <field name="amount" widget="monetary"/>
                            <field name="required_date"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Request Info">
                            <field name="requested_by" widget="many2one_avatar_user"/>
                            <field name="request_date"/>
                            <field name="submitted_date" invisible="state == 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <!-- Bill Summary (visible when approved) -->
                    <group invisible="state not in ('approved', 'closed')"
                           string="Bill Summary">
                        <group>
                            <field name="total_billed" widget="monetary"/>
                            <field name="remaining_billable" widget="monetary"
                                   class="fw-bold"/>
                        </group>
                    </group>
                    <!-- Approval Details -->
                    <group invisible="state == 'draft'" string="Approval Details">
                        <group>
                            <field name="gm_approver_id" widget="many2one_avatar_user"/>
                            <field name="gm_approval_date"/>
                            <field name="gm_comment"/>
                        </group>
                        <group>
                            <field name="md_approver_id" widget="many2one_avatar_user"/>
                            <field name="md_approval_date"/>
                            <field name="md_comment"/>
                        </group>
                    </group>
                    <group invisible="state not in ('rejected', 'cancelled')">
                        <field name="rejection_reason"/>
                        <field name="cancelled_by" invisible="state != 'cancelled'"/>
                        <field name="cancelled_date" invisible="state != 'cancelled'"/>
                    </group>
                    <notebook>
                        <page string="Purpose" name="purpose">
                            <field name="purpose"
                                   placeholder="Describe why these funds are needed..."/>
                        </page>
                        <page string="Attachments" name="attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Bills" name="bills"
                              invisible="state not in ('approved', 'closed')">
                            <field name="bill_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="amount_total_signed" widget="monetary"
                                           string="Amount"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'posted'"
                                           decoration-info="state == 'draft'"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Approval History" name="history">
                            <field name="approval_history_ids" readonly="1">
                                <tree create="false" delete="false" edit="false"
                                      decoration-success="action in ('gm_approve', 'md_approve')"
                                      decoration-danger="action in ('gm_reject', 'md_reject')">
                                    <field name="date" widget="datetime"/>
                                    <field name="action"/>
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                    <field name="previous_state"/>
                                    <field name="new_state"/>
                                    <field name="comment"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Fund Requisition: Search View                                 -->
    <!-- ============================================================ -->
    <record id="view_fund_requisition_search" model="ir.ui.view">
        <field name="name">nn.fund.requisition.search</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <search string="Search Requisitions">
                <field name="name"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="requested_by"/>
                <separator/>
                <filter name="filter_draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_pending" string="Pending Approval"
                        domain="[('state', 'in', ['submitted', 'gm_approved'])]"/>
                <filter name="filter_approved" string="Approved"
                        domain="[('state', '=', 'approved')]"/>
                <filter name="filter_closed" string="Closed"
                        domain="[('state', '=', 'closed')]"/>
                <separator/>
                <filter name="filter_my_requests" string="My Requests"
                        domain="[('requested_by', '=', uid)]"/>
                <filter name="filter_has_remaining" string="Has Remaining Billable"
                        domain="[('remaining_billable', '&gt;', 0), ('state', '=', 'approved')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_by_project" string="Project"
                            context="{'group_by': 'project_id'}"/>
                    <filter name="group_by_expense" string="Expense Head"
                            context="{'group_by': 'expense_head_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Fund Requisition: Action                                      -->
    <!-- ============================================================ -->
    <record id="action_fund_requisition" model="ir.actions.act_window">
        <field name="name">Fund Requisitions</field>
        <field name="res_model">nn.fund.requisition</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_fund_requisition_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new fund requisition
            </p>
            <p>
                Request funds from a project or expense head for spending.
                After approval, vendor bills can be linked to this requisition.
            </p>
        </field>
    </record>

</odoo>
