<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Fund Account: Tree View                                       -->
    <!-- ============================================================ -->
    <record id="view_fund_account_tree" model="ir.ui.view">
        <field name="name">nn.fund.account.tree</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <tree string="Fund Accounts">
                <field name="code" optional="show"/>
                <field name="name"/>
                <field name="account_type"/>
                <field name="total_received" widget="monetary" sum="Total"/>
                <field name="unassigned_balance" widget="monetary" sum="Total"
                       decoration-danger="unassigned_balance &lt; 0"
                       decoration-success="unassigned_balance &gt; 0"/>
                <field name="amount_on_hold" widget="monetary" sum="Total"
                       decoration-warning="amount_on_hold &gt; 0"/>
                <field name="total_assigned" widget="monetary" sum="Total"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Fund Account: Form View                                       -->
    <!-- ============================================================ -->
    <record id="view_fund_account_form" model="ir.ui.view">
        <field name="name">nn.fund.account.form</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <form string="Fund Account">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_fund_incoming)d" type="action"
                                class="oe_stat_button" icon="fa-money"
                                context="{'default_fund_account_id': active_id,
                                          'search_default_fund_account_id': active_id}">
                            <field name="incoming_fund_count" widget="statinfo"
                                   string="Incoming Funds"/>
                        </button>
                        <button name="%(action_fund_allocation)d" type="action"
                                class="oe_stat_button" icon="fa-share-alt"
                                context="{'default_fund_account_id': active_id,
                                          'search_default_fund_account_id': active_id}">
                            <field name="allocation_count" widget="statinfo"
                                   string="Allocations"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Main Bank Account"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Account Details">
                            <field name="code"/>
                            <field name="account_type"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Balance Summary">
                            <field name="total_received" widget="monetary"/>
                            <field name="unassigned_balance" widget="monetary"
                                   class="text-success fw-bold"/>
                            <field name="amount_on_hold" widget="monetary"
                                   class="text-warning"/>
                            <field name="total_assigned" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Account description..."/>
                        </page>
                        <page string="Incoming Funds" name="incoming_funds">
                            <field name="incoming_fund_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="amount" widget="monetary"/>
                                    <field name="transaction_reference"/>
                                    <field name="sender"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'confirmed'"
                                           decoration-info="state == 'draft'"
                                           decoration-danger="state == 'cancelled'"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Allocations" name="allocations">
                            <field name="allocation_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="allocation_type"/>
                                    <field name="project_id"/>
                                    <field name="expense_head_id"/>
                                    <field name="amount" widget="monetary"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'approved'"
                                           decoration-warning="state in ('submitted', 'gm_approved')"
                                           decoration-danger="state in ('rejected', 'cancelled')"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Fund Account: Search View                                     -->
    <!-- ============================================================ -->
    <record id="view_fund_account_search" model="ir.ui.view">
        <field name="name">nn.fund.account.search</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <search string="Search Fund Accounts">
                <field name="name" string="Account" filter_domain="[
                    '|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <separator/>
                <filter name="filter_bank" string="Bank Accounts"
                        domain="[('account_type', '=', 'bank')]"/>
                <filter name="filter_cash" string="Cash Accounts"
                        domain="[('account_type', '=', 'cash')]"/>
                <filter name="filter_has_balance" string="Has Unassigned Balance"
                        domain="[('unassigned_balance', '&gt;', 0)]"/>
                <separator/>
                <filter name="filter_archived" string="Archived"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_type" string="Account Type"
                            context="{'group_by': 'account_type'}"/>
                    <filter name="group_by_company" string="Company"
                            context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Fund Account: Action                                          -->
    <!-- ============================================================ -->
    <record id="action_fund_account" model="ir.actions.act_window">
        <field name="name">Fund Accounts</field>
        <field name="res_model">nn.fund.account</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_fund_account_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first fund account
            </p>
            <p>
                Fund accounts represent bank accounts, cash registers, or
                other financial accounts that receive incoming funds.
            </p>
        </field>
    </record>

</odoo>
