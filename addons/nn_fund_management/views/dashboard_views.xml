<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Pending Approvals Action (filtered allocations/requisitions)   -->
    <!-- ============================================================ -->
    <record id="action_pending_allocations" model="ir.actions.act_window">
        <field name="name">Pending Allocations</field>
        <field name="res_model">nn.fund.allocation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['submitted', 'gm_approved'])]</field>
        <field name="context">{'search_default_filter_pending': 1}</field>
    </record>

    <record id="action_pending_requisitions" model="ir.actions.act_window">
        <field name="name">Pending Requisitions</field>
        <field name="res_model">nn.fund.requisition</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['submitted', 'gm_approved'])]</field>
        <field name="context">{'search_default_filter_pending': 1}</field>
    </record>

    <record id="action_pending_transfers" model="ir.actions.act_window">
        <field name="name">Pending Transfers</field>
        <field name="res_model">nn.fund.transfer</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['submitted', 'gm_approved'])]</field>
        <field name="context">{'search_default_filter_pending': 1}</field>
    </record>

    <!-- Combined Pending Approvals Action Menu -->
    <record id="action_pending_approvals" model="ir.actions.act_window">
        <field name="name">Pending Approvals</field>
        <field name="res_model">nn.fund.allocation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['submitted', 'gm_approved'])]</field>
    </record>

    <!-- ============================================================ -->
    <!-- Fund Management Dashboard                                     -->
    <!-- ============================================================ -->
    <record id="view_fund_dashboard" model="ir.ui.view">
        <field name="name">nn.fund.dashboard</field>
        <field name="model">nn.fund.dashboard</field>
        <field name="arch" type="xml">
            <form string="Fund Management Dashboard" create="false" edit="false" delete="false">
                <sheet>
                    <div class="container-fluid o_fund_dashboard">
                        <h2 class="text-center mb-4">
                            <i class="fa fa-dashboard me-2"/>Fund Management Dashboard
                        </h2>

                        <!-- Quick Actions Row -->
                        <div class="row mb-4">
                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card shadow-sm border-0 bg-primary text-white h-100">
                                    <div class="card-body text-center">
                                        <h6 class="card-title">
                                            <i class="fa fa-money fa-2x d-block mb-2"/>
                                            Fund Accounts
                                        </h6>
                                        <h3 class="mt-2"><field name="total_received" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/></h3>
                                        <a type="action" name="%(action_fund_account)d"
                                           class="btn btn-light btn-sm mt-2 text-primary">View All</a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card shadow-sm border-0 bg-success text-white h-100">
                                    <div class="card-body text-center">
                                        <h6 class="card-title">
                                            <i class="fa fa-download fa-2x d-block mb-2"/>
                                            Unassigned Balance
                                        </h6>
                                        <h3 class="mt-2"><field name="total_unassigned" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/></h3>
                                        <a type="action" name="%(action_fund_incoming)d"
                                           class="btn btn-light btn-sm mt-2 text-success">Incoming Funds</a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card shadow-sm border-0 bg-warning h-100">
                                    <div class="card-body text-center">
                                        <h6 class="card-title">
                                            <i class="fa fa-clock-o fa-2x d-block mb-2"/>
                                            Pending Approvals
                                        </h6>
                                        <h3 class="mt-2"><field name="pending_allocations" readonly="1"/> Allocations</h3>
                                        <a type="action" name="%(action_pending_approvals)d"
                                           class="btn btn-dark btn-sm mt-2">Review</a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card shadow-sm border-0 bg-info text-white h-100">
                                    <div class="card-body text-center">
                                        <h6 class="card-title">
                                            <i class="fa fa-history fa-2x d-block mb-2"/>
                                            Total Spent
                                        </h6>
                                        <h3 class="mt-2"><field name="total_spent" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/></h3>
                                        <a type="action" name="%(action_approval_history)d"
                                           class="btn btn-light btn-sm mt-2 text-info">Audit Trail</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Projects and Expense Heads Row -->
                        <div class="row">
                            <div class="col-lg-6 mb-3">
                                <div class="card shadow-sm h-100">
                                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0">
                                            <i class="fa fa-folder me-2"/>Projects
                                        </h5>
                                        <a type="action" name="%(action_fund_project)d" class="btn btn-sm btn-light text-primary">All Projects</a>
                                    </div>
                                    <div class="card-body p-0">
                                        <field name="project_ids" readonly="1">
                                            <list>
                                                <field name="name"/>
                                                <field name="available_balance" sum="Available"/>
                                                <field name="approved_unspent" sum="Reserved"/>
                                            </list>
                                        </field>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-6 mb-3">
                                <div class="card shadow-sm h-100">
                                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0">
                                            <i class="fa fa-tags me-2"/>Expense Heads
                                        </h5>
                                        <a type="action" name="%(action_fund_expense_head)d" class="btn btn-sm btn-light text-success">All Expenses</a>
                                    </div>
                                    <div class="card-body p-0">
                                        <field name="expense_head_ids" readonly="1">
                                            <list>
                                                <field name="name"/>
                                                <field name="available_balance" sum="Available"/>
                                                <field name="approved_unspent" sum="Reserved"/>
                                            </list>
                                        </field>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Dashboard Action -->
    <record id="action_fund_dashboard" model="ir.actions.server">
        <field name="name">Dashboard</field>
        <field name="model_id" ref="model_nn_fund_dashboard"/>
        <field name="state">code</field>
        <field name="code">
action = model.action_open_dashboard()
        </field>
    </record>

</odoo>
