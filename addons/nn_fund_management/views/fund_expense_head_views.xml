<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Expense Head: Tree View                                       -->
    <!-- ============================================================ -->
    <record id="view_fund_expense_head_tree" model="ir.ui.view">
        <field name="name">nn.fund.expense.head.tree</field>
        <field name="model">nn.fund.expense.head</field>
        <field name="arch" type="xml">
            <tree string="Expense Heads">
                <field name="code" optional="show"/>
                <field name="name"/>
                <field name="total_allocated" widget="monetary" sum="Total"/>
                <field name="available_balance" widget="monetary" sum="Total"
                       decoration-success="available_balance &gt; 0"
                       decoration-danger="available_balance &lt;= 0"/>
                <field name="requisition_hold" widget="monetary"
                       decoration-warning="requisition_hold &gt; 0" optional="show"/>
                <field name="transfer_hold" widget="monetary"
                       decoration-warning="transfer_hold &gt; 0" optional="show"/>
                <field name="total_spent" widget="monetary" sum="Total"/>
                <field name="currency_id" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Expense Head: Form View                                       -->
    <!-- ============================================================ -->
    <record id="view_fund_expense_head_form" model="ir.ui.view">
        <field name="name">nn.fund.expense.head.form</field>
        <field name="model">nn.fund.expense.head</field>
        <field name="arch" type="xml">
            <form string="Expense Head">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Office Rent"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="code"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Available Balance">
                            <field name="available_balance" widget="monetary"
                                   class="text-success fw-bold"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Balance Summary" name="balance">
                            <group>
                                <group string="Incoming">
                                    <field name="total_allocated" widget="monetary"/>
                                    <field name="incoming_transfers" widget="monetary"/>
                                </group>
                                <group string="Outgoing &amp; Holds">
                                    <field name="outgoing_transfers" widget="monetary"/>
                                    <field name="requisition_hold" widget="monetary"/>
                                    <field name="transfer_hold" widget="monetary"/>
                                    <field name="approved_unspent" widget="monetary"/>
                                    <field name="total_spent" widget="monetary"/>
                                </group>
                            </group>
                        </page>
                        <page string="Allocations" name="allocations">
                            <field name="allocation_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="fund_account_id"/>
                                    <field name="amount" widget="monetary"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'approved'"
                                           decoration-warning="state in ('submitted', 'gm_approved')"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Requisitions" name="requisitions">
                            <field name="requisition_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="amount" widget="monetary"/>
                                    <field name="total_billed" widget="monetary"/>
                                    <field name="remaining_billable" widget="monetary"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'approved'"
                                           decoration-warning="state in ('submitted', 'gm_approved')"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Description" name="description">
                            <field name="description"
                                   placeholder="Expense head description..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Expense Head: Search View                                     -->
    <!-- ============================================================ -->
    <record id="view_fund_expense_head_search" model="ir.ui.view">
        <field name="name">nn.fund.expense.head.search</field>
        <field name="model">nn.fund.expense.head</field>
        <field name="arch" type="xml">
            <search string="Search Expense Heads">
                <field name="name" string="Expense Head"
                       filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <separator/>
                <filter name="filter_has_balance" string="Has Available Balance"
                        domain="[('available_balance', '&gt;', 0)]"/>
                <filter name="filter_archived" string="Archived"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_company" string="Company"
                            context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Expense Head: Action                                          -->
    <!-- ============================================================ -->
    <record id="action_fund_expense_head" model="ir.actions.act_window">
        <field name="name">Expense Heads</field>
        <field name="res_model">nn.fund.expense.head</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_fund_expense_head_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new expense head
            </p>
            <p>
                Expense heads categorize recurring expenses like rent,
                salaries, utilities, and marketing.
            </p>
        </field>
    </record>

</odoo>
