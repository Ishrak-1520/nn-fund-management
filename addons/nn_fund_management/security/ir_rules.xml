<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================ -->
        <!-- Multi-Company Record Rules                                    -->
        <!-- ============================================================ -->

        <!-- Fund Account: Company isolation -->
        <record id="rule_fund_account_company" model="ir.rule">
            <field name="name">Fund Account: Multi-Company</field>
            <field name="model_id" ref="model_nn_fund_account"/>
            <field name="domain_force">[
                '|',
                ('company_id', '=', False),
                ('company_id', 'in', company_ids)
            ]</field>
            <field name="groups" eval="[(4, ref('group_fund_user'))]"/>
        </record>

        <!-- Incoming Fund: Company isolation -->
        <record id="rule_fund_incoming_company" model="ir.rule">
            <field name="name">Incoming Fund: Multi-Company</field>
            <field name="model_id" ref="model_nn_fund_incoming"/>
            <field name="domain_force">[
                '|',
                ('company_id', '=', False),
                ('company_id', 'in', company_ids)
            ]</field>
            <field name="groups" eval="[(4, ref('group_fund_user'))]"/>
        </record>

        <!-- Fund Project: Company isolation -->
        <record id="rule_fund_project_company" model="ir.rule">
            <field name="name">Fund Project: Multi-Company</field>
            <field name="model_id" ref="model_nn_fund_project"/>
            <field name="domain_force">[
                '|',
                ('company_id', '=', False),
                ('company_id', 'in', company_ids)
            ]</field>
            <field name="groups" eval="[(4, ref('group_fund_user'))]"/>
        </record>

        <!-- Expense Head: Company isolation -->
        <record id="rule_fund_expense_head_company" model="ir.rule">
            <field name="name">Expense Head: Multi-Company</field>
            <field name="model_id" ref="model_nn_fund_expense_head"/>
            <field name="domain_force">[
                '|',
                ('company_id', '=', False),
                ('company_id', 'in', company_ids)
            ]</field>
            <field name="groups" eval="[(4, ref('group_fund_user'))]"/>
        </record>

        <!-- ============================================================ -->
        <!-- Fund User Record Rules: Own draft records only                -->
        <!-- ============================================================ -->

        <!-- Fund Allocation: Users see own records or approved/submitted ones -->
        <record id="rule_fund_allocation_user" model="ir.rule">
            <field name="name">Fund Allocation: User Access</field>
            <field name="model_id" ref="model_nn_fund_allocation"/>
            <field name="domain_force">[
                '|',
                ('requested_by', '=', user.id),
                ('state', 'not in', ['draft'])
            ]</field>
            <field name="groups" eval="[(4, ref('group_fund_user'))]"/>
        </record>

        <!-- Fund Requisition: Users see own records or non-draft -->
        <record id="rule_fund_requisition_user" model="ir.rule">
            <field name="name">Fund Requisition: User Access</field>
            <field name="model_id" ref="model_nn_fund_requisition"/>
            <field name="domain_force">[
                '|',
                ('requested_by', '=', user.id),
                ('state', 'not in', ['draft'])
            ]</field>
            <field name="groups" eval="[(4, ref('group_fund_user'))]"/>
        </record>

        <!-- Fund Transfer: Users see own records or non-draft -->
        <record id="rule_fund_transfer_user" model="ir.rule">
            <field name="name">Fund Transfer: User Access</field>
            <field name="model_id" ref="model_nn_fund_transfer"/>
            <field name="domain_force">[
                '|',
                ('requested_by', '=', user.id),
                ('state', 'not in', ['draft'])
            ]</field>
            <field name="groups" eval="[(4, ref('group_fund_user'))]"/>
        </record>

        <!-- ============================================================ -->
        <!-- Administrator: Full access (no domain restrictions)           -->
        <!-- ============================================================ -->

        <record id="rule_fund_allocation_admin" model="ir.rule">
            <field name="name">Fund Allocation: Admin Full Access</field>
            <field name="model_id" ref="model_nn_fund_allocation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_fund_administrator'))]"/>
        </record>

        <record id="rule_fund_requisition_admin" model="ir.rule">
            <field name="name">Fund Requisition: Admin Full Access</field>
            <field name="model_id" ref="model_nn_fund_requisition"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_fund_administrator'))]"/>
        </record>

        <record id="rule_fund_transfer_admin" model="ir.rule">
            <field name="name">Fund Transfer: Admin Full Access</field>
            <field name="model_id" ref="model_nn_fund_transfer"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_fund_administrator'))]"/>
        </record>

    </data>
</odoo>
